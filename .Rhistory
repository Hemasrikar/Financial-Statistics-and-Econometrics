#We create a numeric vector of size n-1 and we initialize it, (be careful we have (n-1) returns )
returnsA<-vector(mode = "numeric", length = n-1)
#then, we use a "for loop" in R
for(i in 1:n-1) returnsA[i]<-(prices$`A`[i+1]-prices$`A`[i])/prices$`A`[i]
# Plot for returns
plot(returnsA, type='l', xlab="Days", ylab="Returns on Stock A")
log_returns <- diff(log(prices$`A`), lag=1)
# Plot for Log returns
plot(log_returns, type='l', xlab="Days", ylab="Log returns on stock A", col="steelblue")
# p <- ggplot(prices, aes(x=Date, y=A )) +
#  geom_line(color="turquoise4")+
#  labs(x="Consecutive days", y="Stock A prices", title="Stock A daily prices ")     #create time series plot
