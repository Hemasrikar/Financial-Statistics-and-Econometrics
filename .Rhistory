library(ggplot2)
library(plotly)
library()
p <- prices %>%
ggplot(aes(x = Date, y = A)) +
geom_area(fill = "turquoise4", alpha = 0.4) +
geom_line(color = "turquoise4", linewidth = 0.9) +
labs(
x = "Consecutive days",
y = "Stock A prices",
title = "Stock A daily prices"
) +
theme_minimal(base_size = 14) +
theme(
plot.title = element_text(size = 20, face = "bold", hjust = 0.5),
axis.title.x = element_text(size = 14, margin = ggplot2::margin(t = 10)),
axis.title.y = element_text(size = 14, margin = ggplot2::margin(r = 10)),
panel.grid.minor = element_blank()
)
p <- ggplotly(p)
p
