geom_area(fill="#69b3a2", alpha=0.4) +
geom_line(color="#69b3a2") +
labs(x = "Consecutive Days",
y = "Stock A Prices",
title = "Stock A daily prices")
# Turn it interactive with ggplotly
p <- ggplotly(p)
p   ## Displaying Plot
